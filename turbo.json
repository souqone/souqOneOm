{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["db:generate"]
    },
    "typecheck": {
      "dependsOn": ["db:generate"]
    },
    "test": {
      "dependsOn": ["db:generate"],
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": [
        "node_modules/.prisma/**",
        "node_modules/@prisma/client/**"
      ],
      "cache": true
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    }
  }
}
