{
  "name": "@carone/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest-e2e.config.js --runInBand --forceExit",
    "test:e2e:setup": "dotenv -e .env.test -- npx prisma db push --skip-generate --accept-data-loss",
    "test:e2e:clean": "dotenv -e .env.test -- npx prisma migrate reset --force --skip-seed --skip-generate",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "clean": "rimraf dist node_modules",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "import:cars": "npx ts-node -r dotenv/config src/cars/import-cars.command.ts",
    "seed:cars": "npx ts-node src/cars/seed-cars.ts",
    "seed:marketplace": "npx tsx prisma/seed-marketplace.ts"
  },
  "dependencies": {
    "@carone/types": "*",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/websockets": "^10.4.0",
    "@prisma/client": "^6.0.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.5.0",
    "dotenv": "^16.4.0",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mailtrap": "^3.4.0",
    "meilisearch": "^0.57.0",
    "nodemailer": "^6.9.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.7.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "rimraf": "^6.0.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
  }
}
