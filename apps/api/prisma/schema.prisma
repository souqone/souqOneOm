// ══════════════════════════════════════════════════
// كار وان — مخطط قاعدة البيانات
// Car One — Database Schema
// سلطنة عمان 🇴🇲
// ══════════════════════════════════════════════════

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────
// المستخدم — User
// ──────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  displayName   String?
  avatarUrl     String?
  passwordHash  String?
  googleId      String?   @unique
  bio           String?
  phone         String?
  country       String?
  governorate   String?
  city          String?
  isVerified              Boolean   @default(false)
  emailVerificationCode   String?
  emailVerificationExpiry DateTime?
  passwordResetCode       String?
  passwordResetExpiry     DateTime?
  role                    UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  listings      Listing[]
  favorites     Favorite[]
  sentMessages  Message[]                @relation("SentMessages")
  conversations ConversationParticipant[]
  notifications Notification[]
  refreshTokens RefreshToken[]
  renterBookings Booking[]               @relation("RenterBookings")
  ownerBookings  Booking[]               @relation("OwnerBookings")
  driverJobs     DriverJob[]
  jobApplications JobApplication[]
  messageReactions MessageReaction[]
  spareParts        SparePart[]        @relation("UserSpareParts")
  carServices       CarService[]       @relation("UserCarServices")
  busListings       BusListing[]       @relation("UserBusListings")
  busOffers         BusListingOffer[]  @relation("UserBusOffers")
  equipmentListings  EquipmentListing[]  @relation("UserEquipmentListings")
  equipmentRequests  EquipmentRequest[]  @relation("UserEquipmentRequests")
  equipmentBids      EquipmentBid[]      @relation("UserEquipmentBids")
  operatorListings   OperatorListing[]   @relation("UserOperatorListings")
  reviewsGiven       Review[]            @relation("ReviewsGiven")
  reviewsReceived    Review[]            @relation("ReviewsReceived")
  payments           Payment[]
  subscription       Subscription?
  averageRating      Float?
  reviewCount        Int                 @default(0)
  pushSubscriptions  PushSubscription[]
  loginAudits        LoginAudit[]
  driverProfile      DriverProfile?
  employerProfile    EmployerProfile?
  carrierProfile     CarrierProfile?
  transportRequests  TransportRequest[] @relation("UserTransportRequests")

  @@index([email])
  @@index([username])
  @@map("users")
}

// ──────────────────────────────────────
// سجل محاولات الدخول — LoginAudit
// ──────────────────────────────────────
model LoginAudit {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  success   Boolean
  method    String   @default("EMAIL") // EMAIL | GOOGLE
  ipAddress String?
  userAgent String?
  reason    String?  // e.g. "WRONG_PASSWORD", "ACCOUNT_LOCKED", "GOOGLE_ONLY"
  createdAt DateTime @default(now())

  @@index([email])
  @@index([userId])
  @@index([createdAt])
  @@map("login_audits")
}

// ──────────────────────────────────────
// رمز التجديد — RefreshToken
// ──────────────────────────────────────
model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────
// إعلان السيارة — Listing
// ──────────────────────────────────────
model Listing {
  id                String         @id @default(cuid())
  title             String
  slug              String         @unique
  description       String

  // بيانات السيارة
  make              String
  model             String
  year              Int
  mileage           Int?
  fuelType          FuelType?
  transmission      Transmission?
  bodyType          String?
  exteriorColor     String?
  interior          String?
  engineSize        String?
  horsepower        Int?
  doors             Int?
  seats             Int?
  driveType         String?
  features          String[]

  // نوع الإعلان
  listingType       ListingType    @default(SALE)

  // السعر (بيع)
  price             Decimal        @db.Decimal(12, 2)
  currency          String         @default("OMR")
  isPriceNegotiable Boolean        @default(false)

  // أسعار الإيجار
  dailyPrice        Decimal?       @db.Decimal(12, 2)
  weeklyPrice       Decimal?       @db.Decimal(12, 2)
  monthlyPrice      Decimal?       @db.Decimal(12, 2)
  minRentalDays     Int?           @default(1)
  depositAmount     Decimal?       @db.Decimal(12, 2)
  kmLimitPerDay     Int?
  withDriver        Boolean        @default(false)
  deliveryAvailable Boolean        @default(false)
  insuranceIncluded Boolean        @default(false)
  cancellationPolicy CancellationPolicy?
  availableFrom     DateTime?
  availableTo       DateTime?

  // الحالة والعرض
  condition         ItemCondition  @default(USED)
  status            ListingStatus  @default(DRAFT)
  isPremium         Boolean        @default(false)
  featuredUntil     DateTime?

  // الموقع
  governorate       String?
  city              String?
  latitude          Float?
  longitude         Float?

  viewCount         Int            @default(0)

  sellerId          String
  seller            User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  images            ListingImage[]
  favorites         Favorite[]
  conversations     Conversation[]
  bookings          Booking[]

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([sellerId])
  @@index([make])
  @@index([model])
  @@index([year])
  @@index([status])
  @@index([price])
  @@index([governorate])
  @@index([createdAt])
  @@index([slug])
  @@index([listingType])
  @@map("listings")
}

// ──────────────────────────────────────
// الحجوزات — Booking
// ──────────────────────────────────────
model Booking {
  id                 String             @id @default(cuid())

  entityType         String             @default("CAR") // CAR, BUS, EQUIPMENT

  listingId          String?
  listing            Listing?           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  busListingId       String?
  busListing         BusListing?        @relation(fields: [busListingId], references: [id], onDelete: Cascade)

  equipmentListingId String?
  equipmentListing   EquipmentListing?  @relation(fields: [equipmentListingId], references: [id], onDelete: Cascade)


  renterId           String
  renter             User               @relation("RenterBookings", fields: [renterId], references: [id], onDelete: Cascade)

  ownerId            String
  owner              User               @relation("OwnerBookings", fields: [ownerId], references: [id], onDelete: Cascade)

  startDate          DateTime
  endDate            DateTime
  totalDays          Int
  totalPrice         Decimal            @db.Decimal(12, 2)
  depositAmount      Decimal?           @db.Decimal(12, 2)
  currency           String             @default("OMR")

  status             BookingStatus      @default(PENDING)
  cancellationPolicy CancellationPolicy @default(FREE)

  driverRequested    Boolean            @default(false)
  insuranceSelected  Boolean            @default(false)

  pickupLocation     String?
  dropoffLocation    String?
  notes              String?

  confirmedAt        DateTime?
  cancelledAt        DateTime?
  completedAt        DateTime?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([listingId])
  @@index([busListingId])
  @@index([equipmentListingId])
  @@index([entityType])
  @@index([renterId])
  @@index([ownerId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@map("bookings")
}

// ──────────────────────────────────────
// صور الإعلان — ListingImage
// ──────────────────────────────────────
model ListingImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  order     Int      @default(0)
  isPrimary Boolean  @default(false)

  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([listingId])
  @@map("listing_images")
}

// ──────────────────────────────────────
// المحادثات — Conversation (Generic Entity)
// ──────────────────────────────────────
model Conversation {
  id         String   @id @default(cuid())

  entityType String   // LISTING | SPARE_PART | CAR_SERVICE | JOB
  entityId   String   // ID of the related entity

  // Backward compat — optional relation kept for existing listing conversations
  listingId  String?
  listing    Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([listingId])
  @@map("conversations")
}

// ──────────────────────────────────────
// مشاركي المحادثة — ConversationParticipant
// ──────────────────────────────────────
model ConversationParticipant {
  id             String       @id @default(cuid())

  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  lastReadAt     DateTime?
  isArchived     Boolean   @default(false)

  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_participants")
}

// ──────────────────────────────────────
// الرسائل — Message
// ──────────────────────────────────────
model Message {
  id        String      @id @default(cuid())
  content   String
  type      MessageType @default(TEXT)
  mediaUrl  String?

  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  isRead    Boolean  @default(false)
  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  reactions MessageReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// ──────────────────────────────────────
// ردود الفعل على الرسائل — MessageReaction
// ──────────────────────────────────────
model MessageReaction {
  id        String   @id @default(cuid())
  emoji     String

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, messageId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

// ──────────────────────────────────────
// المفضلة — Favorite
// ──────────────────────────────────────
model Favorite {
  id         String   @id @default(cuid())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  entityType String   @default("LISTING") // LISTING | JOB | SPARE_PART | CAR_SERVICE
  entityId   String

  // Keep optional relation for listing queries
  listingId  String?
  listing    Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([userId, entityType, entityId])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("favorites")
}

// ──────────────────────────────────────
// الإشعارات — Notification
// ──────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ──────────────────────────────────────
// اشتراكات الدفع — PushSubscription
// ──────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

// ──────────────────────────────────────
// وظائف السائقين — DriverJob
// ──────────────────────────────────────
model DriverJob {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  description     String

  jobType         JobType
  employmentType  EmploymentType

  // الراتب
  salary          Decimal?        @db.Decimal(12, 2)
  salaryPeriod    SalaryPeriod?
  currency        String          @default("OMR")

  // متطلبات السائق
  licenseTypes    LicenseType[]
  experienceYears Int?
  minAge          Int?
  maxAge          Int?
  languages       String[]
  nationality     String?

  // نوع المركبة
  vehicleTypes    String[]
  hasOwnVehicle   Boolean         @default(false)

  // الموقع
  governorate     String
  city            String?

  // التواصل
  contactPhone    String?
  contactEmail    String?
  whatsapp        String?

  status          JobStatus       @default(ACTIVE)
  expiresAt       DateTime?
  viewCount       Int             @default(0)

  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  applications    JobApplication[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([jobType])
  @@index([status])
  @@index([governorate])
  @@index([createdAt])
  @@index([slug])
  @@map("driver_jobs")
}

// ──────────────────────────────────────
// طلبات التقديم — JobApplication
// ──────────────────────────────────────
model JobApplication {
  id          String              @id @default(cuid())
  message     String?
  resumeUrl   String?
  status      ApplicationStatus   @default(PENDING)

  jobId       String
  job         DriverJob           @relation(fields: [jobId], references: [id], onDelete: Cascade)

  applicantId String
  applicant   User                @relation(fields: [applicantId], references: [id], onDelete: Cascade)


  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([jobId, applicantId])
  @@index([jobId])
  @@index([applicantId])
  @@map("job_applications")
}


// ──────────────────────────────────────
// بروفايل السائق — DriverProfile
// ──────────────────────────────────────
model DriverProfile {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  licenseTypes    LicenseType[]
  experienceYears Int?
  languages       String[]
  nationality     String?
  vehicleTypes    String[]
  hasOwnVehicle   Boolean       @default(false)
  bio             String?

  governorate     String
  city            String?

  contactPhone    String?
  whatsapp        String?

  isAvailable     Boolean       @default(true)
  isVerified      Boolean       @default(false)

  averageRating   Float?
  reviewCount     Int           @default(0)

  verifications   DriverVerification[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([governorate])
  @@index([isAvailable])
  @@index([isVerified])
  @@map("driver_profiles")
}

// ──────────────────────────────────────
// بروفايل صاحب العمل — EmployerProfile
// ──────────────────────────────────────
model EmployerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName   String?
  companySize   String?  // SMALL, MEDIUM, LARGE
  industry      String?
  bio           String?

  governorate   String
  city          String?
  contactPhone  String?
  whatsapp      String?

  isVerified    Boolean  @default(false)
  averageRating Float?
  reviewCount   Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([governorate])
  @@map("employer_profiles")
}


// ──────────────────────────────────────
// توثيق السائق — DriverVerification
// ──────────────────────────────────────
model DriverVerification {
  id              String               @id @default(cuid())
  driverProfileId String
  driverProfile   DriverProfile        @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)

  licenseImageUrl String
  idImageUrl      String
  notes           String?

  status          VerificationStatus   @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([driverProfileId])
  @@index([status])
  @@map("driver_verifications")
}

// ──────────────────────────────────────
// العلامات التجارية — Brand
// ──────────────────────────────────────
model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  nameAr    String?
  slug      String   @unique
  isPopular Boolean  @default(false)
  models    CarModel[]
  createdAt DateTime @default(now())

  @@index([slug])
  @@index([isPopular])
  @@map("brands")
}

// ──────────────────────────────────────
// موديلات السيارات — CarModel
// ──────────────────────────────────────
model CarModel {
  id        String    @id @default(cuid())
  name      String
  nameAr    String?
  slug      String
  brandId   String
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  years     CarYear[]
  createdAt DateTime  @default(now())

  @@unique([name, brandId])
  @@index([brandId])
  @@index([slug])
  @@map("car_models")
}

// ──────────────────────────────────────
// سنوات السيارات — CarYear
// ──────────────────────────────────────
model CarYear {
  id        String   @id @default(cuid())
  year      Int
  modelId   String
  model     CarModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([year, modelId])
  @@index([modelId])
  @@index([year])
  @@map("car_years")
}

// ──────────────────────────────────────
// التعدادات — Enums
// ──────────────────────────────────────
enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum ListingType {
  SALE
  RENTAL
  WANTED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  RENTED
  ARCHIVED
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
}

enum CancellationPolicy {
  FREE
  FLEXIBLE
  MODERATE
  STRICT
}

enum ItemCondition {
  NEW
  USED
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  SYSTEM
}

enum JobType {
  OFFERING
  HIRING
}

enum JobStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  TEMPORARY
  CONTRACT
}

enum SalaryPeriod {
  DAILY
  MONTHLY
  YEARLY
  NEGOTIABLE
}

enum LicenseType {
  LIGHT
  HEAVY
  TRANSPORT
  BUS
  MOTORCYCLE
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}


enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}


enum NotificationType {
  MESSAGE
  LISTING_SOLD
  LISTING_FAVORITED
  PRICE_DROP
  SYSTEM
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  RETURN_REMINDER
  JOB_APPLICATION
  JOB_APPLICATION_ACCEPTED
  JOB_APPLICATION_REJECTED
  REVIEW_RECEIVED
  PAYMENT_SUCCESS
  SUBSCRIPTION_ACTIVATED
  FEATURED_EXPIRED
  LISTING_CREATED
  LISTING_UPDATED
  LISTING_DELETED
  LISTING_STATUS_CHANGED
  JOB_RECOMMENDATION
  TRANSPORT_QUOTE_RECEIVED
  TRANSPORT_BOOKING_CONFIRMED
  TRANSPORT_BOOKING_CANCELLED
  TRANSPORT_REQUEST_CLOSED
}

// ══════════════════════════════════════════════════
// الأقسام الجديدة — New Marketplace Categories
// ══════════════════════════════════════════════════

// ── تعدادات قطع الغيار ──
enum PartCategory {
  ENGINE
  BODY
  ELECTRICAL
  SUSPENSION
  BRAKES
  INTERIOR
  TIRES
  BATTERIES
  OILS
  ACCESSORIES
  OTHER
}

enum PartCondition {
  NEW
  USED
  REFURBISHED
}

// ── تعدادات خدمات السيارات ──
enum ServiceType {
  MAINTENANCE
  CLEANING
  MODIFICATION
  INSPECTION
  BODYWORK
  ACCESSORIES_INSTALL
  KEYS_LOCKS
  TOWING
  OTHER_SERVICE
}

enum ProviderType {
  WORKSHOP
  INDIVIDUAL
  MOBILE
  COMPANY
}


// ── تعدادات المركبات الموسعة ──
enum VehicleCategory {
  CAR
  MOTORCYCLE
  MARINE
  HEAVY_EQUIPMENT
}

// ──────────────────────────────────────
// قطع الغيار — SparePart
// ──────────────────────────────────────
model SparePart {
  id                String        @id @default(cuid())
  title             String
  slug              String        @unique
  description       String
  partCategory      PartCategory
  condition         PartCondition @default(USED)
  partNumber        String?
  compatibleMakes   String[]
  compatibleModels  String[]
  yearFrom          Int?
  yearTo            Int?
  isOriginal        Boolean       @default(false)
  price             Decimal       @db.Decimal(12, 2)
  currency          String        @default("OMR")
  isPriceNegotiable Boolean       @default(false)
  governorate       String?
  city              String?
  latitude          Float?
  longitude         Float?
  contactPhone      String?
  whatsapp          String?
  status            ListingStatus @default(ACTIVE)
  viewCount         Int           @default(0)

  sellerId          String
  seller            User          @relation("UserSpareParts", fields: [sellerId], references: [id], onDelete: Cascade)
  images            SparePartImage[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([sellerId])
  @@index([partCategory])
  @@index([status])
  @@index([createdAt])
  @@index([slug])
  @@map("spare_parts")
}

model SparePartImage {
  id          String    @id @default(cuid())
  url         String
  isPrimary   Boolean   @default(false)
  order       Int       @default(0)
  sparePartId String
  sparePart   SparePart @relation(fields: [sparePartId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([sparePartId])
  @@map("spare_part_images")
}

// ──────────────────────────────────────
// خدمات السيارات — CarService
// ──────────────────────────────────────
model CarService {
  id                String       @id @default(cuid())
  title             String
  slug              String       @unique
  description       String
  serviceType       ServiceType
  providerType      ProviderType
  providerName      String
  specializations   String[]
  priceFrom         Decimal?     @db.Decimal(12, 2)
  priceTo           Decimal?     @db.Decimal(12, 2)
  currency          String       @default("OMR")
  isHomeService     Boolean      @default(false)
  workingHoursOpen  String?
  workingHoursClose String?
  workingDays       String[]
  governorate       String
  city              String?
  address           String?
  latitude          Float?
  longitude         Float?
  contactPhone      String?
  whatsapp          String?
  website           String?
  status            ListingStatus @default(ACTIVE)
  viewCount         Int           @default(0)

  userId            String
  user              User          @relation("UserCarServices", fields: [userId], references: [id], onDelete: Cascade)
  images            CarServiceImage[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@index([serviceType])
  @@index([governorate])
  @@index([status])
  @@index([slug])
  @@map("car_services")
}

model CarServiceImage {
  id           String     @id @default(cuid())
  url          String
  isPrimary    Boolean    @default(false)
  order        Int        @default(0)
  carServiceId String
  carService   CarService @relation(fields: [carServiceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([carServiceId])
  @@map("car_service_images")
}


// ══════════════════════════════════════════════════
// قسم الحافلات — Bus Marketplace
// ══════════════════════════════════════════════════

enum BusListingType {
  BUS_SALE
  BUS_SALE_WITH_CONTRACT
  BUS_RENT
  BUS_CONTRACT
  BUS_REQUEST
}

enum BusOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum BusType {
  MINI_BUS
  MEDIUM_BUS
  LARGE_BUS
  COASTER
  SCHOOL_BUS
}

enum ContractType {
  SCHOOL
  COMPANY
  GOVERNMENT
  TOURISM
  OTHER_CONTRACT
}

model BusListing {
  id                String          @id @default(cuid())
  title             String
  slug              String          @unique
  description       String

  busListingType    BusListingType
  busType           BusType

  make              String
  model             String
  year              Int
  capacity          Int
  mileage           Int?
  fuelType          FuelType?
  transmission      Transmission?
  condition         ItemCondition   @default(USED)
  features          String[]
  plateNumber       String?

  price             Decimal?        @db.Decimal(12, 2)
  currency          String          @default("OMR")
  isPriceNegotiable Boolean         @default(false)

  contractType      ContractType?
  contractClient    String?
  contractMonthly   Decimal?        @db.Decimal(12, 2)
  contractDuration  Int?
  contractExpiry    DateTime?

  dailyPrice        Decimal?        @db.Decimal(12, 2)
  monthlyPrice      Decimal?        @db.Decimal(12, 2)
  minRentalDays     Int?
  depositAmount     Decimal?        @db.Decimal(12, 2)
  kmLimitPerDay     Int?
  withDriver        Boolean         @default(false)
  deliveryAvailable Boolean         @default(false)
  insuranceIncluded Boolean         @default(false)
  cancellationPolicy CancellationPolicy?
  availableFrom     DateTime?
  availableTo       DateTime?

  requestPassengers Int?
  requestRoute      String?
  requestSchedule   String?

  governorate       String?
  city              String?
  latitude          Float?
  longitude         Float?

  contactPhone      String?
  whatsapp          String?

  status            ListingStatus   @default(ACTIVE)
  isPremium         Boolean         @default(false)
  featuredUntil     DateTime?
  viewCount         Int             @default(0)

  userId            String
  user              User            @relation("UserBusListings", fields: [userId], references: [id], onDelete: Cascade)
  images            BusListingImage[]
  offers            BusListingOffer[] @relation("BusRequestOffers")
  statusLogs        BusListingStatusLog[] @relation("BusStatusLogs")
  priceHistory      BusListingPriceHistory[] @relation("BusPriceHistory")
  bookings          Booking[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  @@index([userId])
  @@index([busListingType])
  @@index([busType])
  @@index([status])
  @@index([governorate])
  @@index([createdAt])
  @@index([slug])
  @@index([deletedAt])
  @@map("bus_listings")
}

model BusListingImage {
  id             String      @id @default(cuid())
  url            String
  isPrimary      Boolean     @default(false)
  order          Int         @default(0)
  busListingId   String
  busListing     BusListing  @relation(fields: [busListingId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())

  @@index([busListingId])
  @@map("bus_listing_images")
}

model BusListingPriceHistory {
  id             String     @id @default(cuid())
  oldPrice       Decimal?   @db.Decimal(12, 2)
  newPrice       Decimal?   @db.Decimal(12, 2)
  changedBy      String
  busListingId   String
  busListing     BusListing @relation("BusPriceHistory", fields: [busListingId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())

  @@index([busListingId])
  @@map("bus_listing_price_history")
}

model BusListingStatusLog {
  id             String        @id @default(cuid())
  fromStatus     ListingStatus
  toStatus       ListingStatus
  changedBy      String
  busListingId   String
  busListing     BusListing    @relation("BusStatusLogs", fields: [busListingId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@index([busListingId])
  @@map("bus_listing_status_logs")
}

model BusListingOffer {
  id                String          @id @default(cuid())
  message           String?
  proposedPrice     Decimal?        @db.Decimal(12, 2)

  status            BusOfferStatus  @default(PENDING)

  requestListingId  String
  requestListing    BusListing      @relation("BusRequestOffers", fields: [requestListingId], references: [id], onDelete: Cascade)

  sellerUserId      String
  seller            User            @relation("UserBusOffers", fields: [sellerUserId], references: [id], onDelete: Cascade)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([requestListingId, sellerUserId])
  @@index([requestListingId])
  @@index([sellerUserId])
  @@map("bus_listing_offers")
}

// ══════════════════════════════════════════════════
// سوق المعدات والخدمات — Equipment & Services Marketplace
// ══════════════════════════════════════════════════

enum EquipmentType {
  EXCAVATOR
  CRANE
  LOADER
  BULLDOZER
  FORKLIFT
  CONCRETE_MIXER
  GENERATOR
  COMPRESSOR
  SCAFFOLDING
  WELDING_MACHINE
  TRUCK
  DUMP_TRUCK
  WATER_TANKER
  LIGHT_EQUIPMENT
  OTHER_EQUIPMENT
}

enum EquipmentListingType {
  EQUIPMENT_SALE
  EQUIPMENT_RENT
}

enum EquipmentRequestStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum OperatorType {
  DRIVER
  OPERATOR
  TECHNICIAN
  MAINTENANCE
}

// ──────────────────────────────────────
// إعلان معدات — EquipmentListing
// ──────────────────────────────────────
model EquipmentListing {
  id                  String               @id @default(cuid())
  title               String
  slug                String               @unique
  description         String

  equipmentType       EquipmentType
  listingType         EquipmentListingType

  make                String?
  model               String?
  year                Int?
  condition           ItemCondition        @default(USED)
  capacity            String?
  power               String?
  weight              String?
  hoursUsed           Int?
  features            String[]

  price               Decimal?             @db.Decimal(12, 2)
  dailyPrice          Decimal?             @db.Decimal(12, 2)
  weeklyPrice         Decimal?             @db.Decimal(12, 2)
  monthlyPrice        Decimal?             @db.Decimal(12, 2)
  currency            String               @default("OMR")
  isPriceNegotiable   Boolean              @default(false)
  withOperator        Boolean              @default(false)
  deliveryAvailable   Boolean              @default(false)
  minRentalDays       Int?
  depositAmount       Decimal?             @db.Decimal(12, 2)
  kmLimitPerDay       Int?
  insuranceIncluded   Boolean              @default(false)
  cancellationPolicy  CancellationPolicy?
  availableFrom       DateTime?
  availableTo         DateTime?

  governorate         String?
  city                String?
  latitude            Float?
  longitude           Float?

  contactPhone        String?
  whatsapp            String?

  status              ListingStatus        @default(ACTIVE)
  isPremium           Boolean              @default(false)
  featuredUntil       DateTime?
  viewCount           Int                  @default(0)

  userId              String
  user                User                 @relation("UserEquipmentListings", fields: [userId], references: [id], onDelete: Cascade)
  images              EquipmentListingImage[]
  bookings            Booking[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([userId])
  @@index([equipmentType])
  @@index([listingType])
  @@index([status])
  @@index([governorate])
  @@index([createdAt])
  @@index([slug])
  @@map("equipment_listings")
}

model EquipmentListingImage {
  id                   String             @id @default(cuid())
  url                  String
  isPrimary            Boolean            @default(false)
  order                Int                @default(0)
  equipmentListingId   String
  equipmentListing     EquipmentListing   @relation(fields: [equipmentListingId], references: [id], onDelete: Cascade)
  createdAt            DateTime           @default(now())

  @@index([equipmentListingId])
  @@map("equipment_listing_images")
}

// ──────────────────────────────────────
// طلب معدات — EquipmentRequest
// ──────────────────────────────────────
model EquipmentRequest {
  id                  String                  @id @default(cuid())
  title               String
  slug                String                  @unique
  description         String

  equipmentType       EquipmentType
  quantity            Int                     @default(1)

  budgetMin           Decimal?                @db.Decimal(12, 2)
  budgetMax           Decimal?                @db.Decimal(12, 2)
  currency            String                  @default("OMR")
  rentalDuration      String?
  startDate           DateTime?
  endDate             DateTime?
  withOperator        Boolean                 @default(false)

  governorate         String?
  city                String?
  siteDetails         String?
  latitude            Float?
  longitude           Float?

  contactPhone        String?
  whatsapp            String?

  requestStatus       EquipmentRequestStatus  @default(OPEN)
  viewCount           Int                     @default(0)

  userId              String
  user                User                    @relation("UserEquipmentRequests", fields: [userId], references: [id], onDelete: Cascade)
  bids                EquipmentBid[]
  images              EquipmentRequestImage[]

  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([userId])
  @@index([equipmentType])
  @@index([requestStatus])
  @@index([governorate])
  @@index([createdAt])
  @@index([slug])
  @@map("equipment_requests")
}

// صور طلبات المعدات — EquipmentRequestImage
model EquipmentRequestImage {
  id          String           @id @default(cuid())
  url         String
  requestId   String
  request     EquipmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@index([requestId])
  @@map("equipment_request_images")
}

// ──────────────────────────────────────
// عروض المعدات — EquipmentBid
// ──────────────────────────────────────
model EquipmentBid {
  id                  String                @id @default(cuid())
  price               Decimal               @db.Decimal(12, 2)
  currency            String                @default("OMR")
  availability        String
  notes               String?
  withOperator        Boolean               @default(false)

  bidStatus           BidStatus             @default(PENDING)

  requestId           String
  request             EquipmentRequest      @relation(fields: [requestId], references: [id], onDelete: Cascade)

  userId              String
  user                User                  @relation("UserEquipmentBids", fields: [userId], references: [id], onDelete: Cascade)

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([requestId])
  @@index([userId])
  @@index([bidStatus])
  @@map("equipment_bids")
}

// ──────────────────────────────────────
// خدمات التشغيل — OperatorListing
// ──────────────────────────────────────
model OperatorListing {
  id                  String           @id @default(cuid())
  title               String
  slug                String           @unique
  description         String

  operatorType        OperatorType
  specializations     String[]
  experienceYears     Int?
  equipmentTypes      EquipmentType[]
  certifications      String[]

  dailyRate           Decimal?         @db.Decimal(12, 2)
  hourlyRate          Decimal?         @db.Decimal(12, 2)
  currency            String           @default("OMR")
  isPriceNegotiable   Boolean          @default(false)

  governorate         String?
  city                String?
  latitude            Float?
  longitude           Float?

  contactPhone        String?
  whatsapp            String?

  status              ListingStatus    @default(ACTIVE)
  viewCount           Int              @default(0)

  userId              String
  user                User             @relation("UserOperatorListings", fields: [userId], references: [id], onDelete: Cascade)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([userId])
  @@index([operatorType])
  @@index([status])
  @@index([governorate])
  @@index([slug])
  @@map("operator_listings")
}

// ══════════════════════════════════════════════════
// التقييمات — Reviews
// ══════════════════════════════════════════════════

enum ReviewEntityType {
  LISTING
  BUS_LISTING
  EQUIPMENT_LISTING
  BOOKING
  OPERATOR_LISTING
  DRIVER_PROFILE
  EMPLOYER_PROFILE
  CARRIER_PROFILE
}

model Review {
  id           String           @id @default(cuid())
  rating       Int              // 1-5
  comment      String?

  entityType   ReviewEntityType
  entityId     String

  reviewerId   String
  reviewer     User             @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)

  revieweeId   String
  reviewee     User             @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  reply        ReviewReply?

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([reviewerId, entityType, entityId])
  @@index([revieweeId])
  @@index([entityType, entityId])
  @@index([rating])
  @@map("reviews")
}

model ReviewReply {
  id        String   @id @default(cuid())
  body      String

  reviewId  String   @unique
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("review_replies")
}

// ══════════════════════════════════════════════════
// المدفوعات — Payments & Subscriptions (Thawani)
// ══════════════════════════════════════════════════

enum PaymentType {
  FEATURED
  SUBSCRIPTION
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum SubscriptionPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model Payment {
  id                String        @id @default(cuid())

  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount            Int           // amount in baisa (1 OMR = 1000 baisa)
  currency          String        @default("OMR")
  type              PaymentType
  status            PaymentStatus @default(PENDING)

  thawaniSessionId  String?       @unique
  thawaniPaymentId  String?
  idempotencyKey    String?       @unique

  entityType        String?       // e.g. LISTING, BUS_LISTING
  entityId          String?
  metadata          Json?
  ipAddress         String?

  createdAt         DateTime      @default(now())
  paidAt            DateTime?

  subscription      Subscription?
  events            PaymentEvent[]

  @@index([userId])
  @@index([status])
  @@index([thawaniSessionId])
  @@index([idempotencyKey])
  @@index([ipAddress])
  @@map("payments")
}

model PaymentEvent {
  id        String   @id @default(cuid())

  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  event     String   // CREATED, SESSION_CREATED, WEBHOOK_RECEIVED, VERIFIED, PAID, FAILED, RECONCILED
  data      Json?    // extra context

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([event])
  @@map("payment_events")
}

model Subscription {
  id          String             @id @default(cuid())

  userId      String             @unique
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan        SubscriptionPlan   @default(BASIC)
  status      SubscriptionStatus @default(ACTIVE)

  startDate   DateTime           @default(now())
  endDate     DateTime?
  autoRenew   Boolean            @default(true)

  paymentId   String?            @unique
  payment     Payment?           @relation(fields: [paymentId], references: [id])

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

// ══════════════════════════════════════════════════
// سوق النقل — Transport Marketplace
// ══════════════════════════════════════════════════

enum TransportServiceType {
  GOODS
  FURNITURE
  CONSTRUCTION
  HEAVY
  BACKLOAD
  EQUIPMENT
}

enum TransportRequestStatus {
  OPEN
  QUOTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum VehicleType {
  PICKUP
  VAN
  TRUCK_SMALL
  TRUCK_LARGE
  TRAILER
  EXCAVATOR
  TIPPER
  CRANE
  OTHER
}

model CarrierProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName     String?
  bio             String?
  vehicleTypes    VehicleType[]
  serviceTypes    TransportServiceType[]
  governorate     String
  city            String?
  contactPhone    String?
  whatsapp        String?

  isAvailable     Boolean     @default(false)
  isVerified      Boolean     @default(false)

  completedTrips  Int         @default(0)
  averageRating   Float       @default(0)
  reviewCount     Int         @default(0)

  quotes          TransportQuote[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([governorate, isAvailable])
  @@map("carrier_profiles")
}

model TransportRequest {
  id              String                  @id @default(cuid())
  userId          String
  user            User                    @relation("UserTransportRequests", fields: [userId], references: [id], onDelete: Cascade)

  serviceType     TransportServiceType
  status          TransportRequestStatus  @default(OPEN)

  fromGovernorate String
  fromCity        String?
  fromAddress     String
  fromLat         Float?
  fromLng         Float?

  toGovernorate   String
  toCity          String?
  toAddress       String
  toLat           Float?
  toLng           Float?

  cargoDescription String
  weightTons      Float?
  requiresHelper  Boolean     @default(false)
  notes           String?

  scheduledAt     DateTime?
  isFlexible      Boolean     @default(false)

  budgetMin       Decimal?    @db.Decimal(10, 3)
  budgetMax       Decimal?    @db.Decimal(10, 3)
  currency        String      @default("OMR")

  viewCount       Int         @default(0)
  expiresAt       DateTime?

  quotes          TransportQuote[]
  booking         TransportBooking?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status, fromGovernorate])
  @@index([userId])
  @@index([serviceType, status])
  @@map("transport_requests")
}

model TransportQuote {
  id              String        @id @default(cuid())
  requestId       String
  request         TransportRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  carrierId       String
  carrier         CarrierProfile   @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  status          QuoteStatus   @default(PENDING)

  price           Decimal       @db.Decimal(10, 3)
  currency        String        @default("OMR")
  estimatedHours  Float?
  message         String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking         TransportBooking?

  @@unique([requestId, carrierId])
  @@index([requestId, status])
  @@index([carrierId])
  @@map("transport_quotes")
}

model TransportBooking {
  id              String        @id @default(cuid())
  requestId       String        @unique
  request         TransportRequest @relation(fields: [requestId], references: [id])
  quoteId         String        @unique
  quote           TransportQuote   @relation(fields: [quoteId], references: [id])

  status          TransportRequestStatus @default(IN_PROGRESS)
  confirmedAt     DateTime      @default(now())
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("transport_bookings")
}
